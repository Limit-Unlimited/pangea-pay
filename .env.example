# ─── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pangea_pay

# ─── Auth ─────────────────────────────────────────────────────
AUTH_SECRET=                    # 32+ char random string — run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ─── Apps ─────────────────────────────────────────────────────
BACKOFFICE_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ─── Email (dev: Mailpit) ─────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@pangea.local

# ─── KYC Provider ─────────────────────────────────────────────
KYC_PROVIDER=mock               # mock | <provider-name>
KYC_API_KEY=
KYC_API_URL=
KYC_WEBHOOK_SECRET=

# ─── Screening Provider ───────────────────────────────────────
SCREENING_PROVIDER=mock         # mock | <provider-name>
SCREENING_API_KEY=
SCREENING_API_URL=
SCREENING_WEBHOOK_SECRET=

# ─── FX Rate Provider ─────────────────────────────────────────
FX_PROVIDER=mock                # mock | <provider-name>
FX_API_KEY=
FX_API_URL=

# ─── SMS Provider ─────────────────────────────────────────────
SMS_PROVIDER=mock               # mock | <provider-name>
SMS_API_KEY=
SMS_FROM=
