# ─── Database ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pangea_pay

# ─── Auth ─────────────────────────────────────────────────────
AUTH_SECRET=                    # 32+ char random string — run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ─── Apps ─────────────────────────────────────────────────────
BACKOFFICE_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ─── Web App ──────────────────────────────────────────────────
# The tenant ID for the web app to scope all customer operations
# Get from the tenants table: SELECT id FROM tenants LIMIT 1;
DEFAULT_TENANT_ID=

# ─── Email (dev: Mailpit) ─────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@pangea.local

# ─── KYC Provider ─────────────────────────────────────────────
KYC_PROVIDER=mock               # mock | <provider-name>
KYC_API_KEY=
KYC_API_URL=
KYC_WEBHOOK_SECRET=

# ─── Screening Provider ───────────────────────────────────────
SCREENING_PROVIDER=mock         # mock | <provider-name>
SCREENING_API_KEY=
SCREENING_API_URL=
SCREENING_WEBHOOK_SECRET=

# ─── FX Rate Provider ─────────────────────────────────────────
# Development/staging: Frankfurter (free, no key required)
# Production: replace with a commercial provider
FX_PROVIDER=frankfurter         # frankfurter | <provider-name>
FX_API_URL=https://api.frankfurter.dev/v2
FX_API_KEY=                     # not required for Frankfurter
FX_QUOTE_TTL_SECONDS=30         # quote validity window (seconds)

# ─── SMS Provider ─────────────────────────────────────────────
SMS_PROVIDER=mock               # mock | <provider-name>
SMS_API_KEY=
SMS_FROM=

# ─── Payout / Banking Partner ─────────────────────────────────
# Development: mock adapter (no connectivity required)
# Production: replace with real provider once commercial partner is finalised
PAYOUT_PROVIDER=mock            # mock | <provider-name>
